# ─────────────────────────────────────────
#  Singarr — Environment Configuration
# ─────────────────────────────────────────
#  Only JWT_SECRET is required here.
#  All other keys (Lidarr, Plex, Last.fm, Fanart.tv)
#  can be entered through the Admin panel after setup.

# Required — generate with: openssl rand -hex 32
JWT_SECRET=changeme_use_a_long_random_string_here

# Optional — can also be set in Admin → Settings
PLEX_CLIENT_ID=singarr
